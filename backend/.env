# ============================================================
# GraminRozgar Backend - Environment Configuration
# ============================================================

# --- MongoDB ---
# Local development: mongodb://localhost:27017/graminrozgar
# Docker (via docker-compose): mongodb://mongodb:27017/graminrozgar
MONGO_URL=mongodb://localhost:27017/graminrozgar

# --- JWT Authentication ---
# Change this to a long, random string in production!
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=graminrozgar_secret_key_2025

# --- OpenRouter API Key ---
# Used for: chatbot, text translation, detail extraction (Gemini 2.5)
# Get your key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# --- Server Port ---
PORT=8001

# --- Sarvam AI ---
# Used for: Indic-specific transcribe, translate, etc.
# Get your key from: https://sarvam.ai/
SARVAM_API_KEY=your_sarvam_api_key_here
