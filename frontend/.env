# ============================================================
# GraminRozgar Frontend - Environment Configuration
# ============================================================
# NOTE: All React env vars MUST be prefixed with REACT_APP_
# Restart the dev server after changing these values.

# --- Backend API URL ---
# Local development: http://localhost:8001/api
# Docker / production: change to your deployed backend URL
REACT_APP_BACKEND_URL=http://localhost:8001/api
